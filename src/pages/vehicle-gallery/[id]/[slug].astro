<script is:inline>	
	(function () {
		const slider = document.getElementById('vehicle-slider');
		if (!slider) return;
		const trackNode = slider.querySelector('.vehicle-slider__track');
		const slides = slider.querySelectorAll('.vehicle-slider__slide');
		const prev = slider.querySelector('.vehicle-slider__prev');
		const next = slider.querySelector('.vehicle-slider__next');
		const dots = slider.querySelectorAll('.vehicle-slider__dot');
		const total = slides.length;
		if (total <= 1 || !trackNode) return;

		const track = trackNode instanceof HTMLElement ? trackNode : null;
		if (!track) return;

		var index = 0;
		var touchStartX = 0;
		var touchStartY = 0;
		var touchStartIndex = 0;
		var touchIsHorizontal = null;

		function goTo(i) {
			index = Math.max(0, Math.min(i, total - 1));
			track.style.transition = '';
			track.style.transform = 'translate3d(-' + (index * 100) + '%, 0, 0)';
			dots.forEach(function (dot, j) {
				dot.setAttribute('aria-selected', j === index ? 'true' : 'false');
				dot.classList.toggle('is-active', j === index);
			});
		}

		if (prev) prev.addEventListener('click', function () { goTo(index - 1); });
		if (next) next.addEventListener('click', function () { goTo(index + 1); });
		dots.forEach(function (dot, i) { dot.addEventListener('click', function () { goTo(i); }); });

		track.addEventListener('touchstart', function (e) {
			if (e.touches.length !== 1) return;
			touchStartX = e.touches[0].clientX;
			touchStartY = e.touches[0].clientY;
			touchStartIndex = index;
			touchIsHorizontal = null;
			track.style.transition = 'none';
		}, { passive: true });

		track.addEventListener('touchmove', function (e) {
			if (e.touches.length !== 1) return;
			var x = e.touches[0].clientX;
			var y = e.touches[0].clientY;
			var deltaX = x - touchStartX;
			var deltaY = y - touchStartY;
			if (touchIsHorizontal === null) {
				touchIsHorizontal = Math.abs(deltaX) > Math.abs(deltaY);
			}
			if (touchIsHorizontal && Math.abs(deltaX) > 5) {
				e.preventDefault();
			}
			var trackWidth = track.offsetWidth;
			var minOffset = -(total - 1) * trackWidth;
			var maxOffset = 0;
			var offsetPx = -touchStartIndex * trackWidth + deltaX;
			offsetPx = Math.max(minOffset, Math.min(maxOffset, offsetPx));
			track.style.transform = 'translate3d(' + offsetPx + 'px, 0, 0)';
		}, { passive: false });

		track.addEventListener('touchend', function (e) {
			track.style.transition = '';
			if (e.changedTouches.length !== 1) return;
			var endX = e.changedTouches[0].clientX;
			var deltaX = endX - touchStartX;
			var trackWidth = track.offsetWidth;
			var threshold = trackWidth * 0.2;
			if (deltaX > threshold) {
				goTo(touchStartIndex - 1);
			} else if (deltaX < -threshold) {
				goTo(touchStartIndex + 1);
			} else {
				goTo(touchStartIndex);
			}
		}, { passive: true });

		goTo(0);
	})();

	// Explore Products - Fetch Tires (front & rear separately when staggered)
	(function () {
		var exploreEl = document.getElementById('explore-products');
		if (!exploreEl) return;

		var frontSize = exploreEl.getAttribute('data-front-tire-size') || '';
		var rearSize = exploreEl.getAttribute('data-rear-tire-size') || '';
		if (!frontSize && !rearSize) return;

		function getFirstNode(result) {
			var edges = result && result.data && result.data.site &&
				result.data.site.search && result.data.site.search.searchProducts &&
				result.data.site.search.searchProducts.products &&
				result.data.site.search.searchProducts.products.edges;
			return (edges && edges.length > 0) ? edges[0].node : null;
		}

		function renderTire(prefix, node) {
			var link = document.getElementById('explore-' + prefix + '-tire-link');
			var img = link ? link.querySelector('img') : null;
			var name = document.getElementById('explore-' + prefix + '-tire-name');
			var price = document.getElementById('explore-' + prefix + '-tire-price');

			if (img && node.defaultImage && node.defaultImage.urlOriginal) {
				img.src = node.defaultImage.urlOriginal;
				img.alt = node.defaultImage.altText || node.name || 'Tire';
			}
			if (link && node.path) {
				link.href = 'https://www.threepiece.us' + node.path;
			}
			if (name) name.textContent = node.name || '';
			if (price && node.prices && node.prices.price) {
				price.textContent = node.prices.price.formatted;
			}
		}

		function fetchTiresForSize(size, prefix) {
			return fetch('/api/tires', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ sizes: [size] }),
			})
				.then(function (response) { return response.json(); })
				.then(function (result) {
					var node = getFirstNode(result);
					if (node) renderTire(prefix, node);
				})
				.catch(function (error) { console.error(prefix + ' tire fetch error:', error); });
		}

		// Always fetch front
		if (frontSize) fetchTiresForSize(frontSize, 'front');

		// Fetch rear separately only when sizes differ
		if (rearSize && rearSize !== frontSize) {
			fetchTiresForSize(rearSize, 'rear');
		}
	})();
</script>
