---
interface Props {
  pageTitle?: string;
  metaDescription?: string;
  schemaJsonLd?: string;
}

const { pageTitle: titleProp, metaDescription, schemaJsonLd } = Astro.props;
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const footerResponse = await fetch('https://www.threepiece.us/footer-only', { redirect: 'follow' });
const footerHtml = footerResponse.ok ? await footerResponse.text() : '';

const pageTitle = titleProp ?? 'Vehicle Gallery | Three Piece';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    {metaDescription && (
      <meta name="description" content={metaDescription.replace(/"/g, '&quot;')} />
    )}
    {schemaJsonLd && (
      <script type="application/ld+json" set:html={schemaJsonLd} />
    )}
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
